<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/gray_light">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header: Applicant Info -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:id="@+id/tvUserName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="APPLICANT NAME"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="@color/primary"/>

            <TextView
                android:id="@+id/tvLoanAmount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="UGX 0"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/secondary"/>
        </RelativeLayout>

        <TextView
            android:id="@+id/tvDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Requested: 01 Jan 2024"
            android:textSize="12sp"
            android:alpha="0.6"
            android:layout_marginTop="4dp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/gray_light"
            android:layout_marginVertical="12dp"/>

        <!-- Expanded Application Details -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="APPLICATION DETAILS"
            android:textSize="10sp"
            android:textStyle="bold"
            android:alpha="0.5"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvApplicantAddress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Address: ..."
            android:textSize="13sp"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/tvApplicantPhone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Phone: ..."
            android:textSize="13sp"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="GUARANTOR INFORMATION"
            android:textSize="10sp"
            android:textStyle="bold"
            android:alpha="0.5"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvGuarantorName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Name: ..."
            android:textSize="13sp"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/tvGuarantorPhone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Phone: ..."
            android:textSize="13sp"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:id="@+id/tvSignatureStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✓ Electronically Signed"
            android:textColor="@android:color/holo_green_dark"
            android:textStyle="italic"
            android:textSize="12sp"
            android:layout_marginBottom="20dp"/>

        <!-- Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnApprove"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="APPROVE LOAN"
                android:layout_marginEnd="8dp"
                android:backgroundTint="@android:color/holo_green_dark"/>

            <Button
                android:id="@+id/btnReject"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="REJECT"
                android:textColor="@android:color/holo_red_dark"/>
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
